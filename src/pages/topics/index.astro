---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

let topics = [];
try { topics = await getCollection('topics'); } catch {}
---

<BaseLayout title="Topics | Redemocratize">
  <div class="container py-8">
    <div class="max-w-4xl mx-auto">
      <header class="mb-12">
        <h1 class="text-4xl lg:text-5xl font-bold font-heading mb-4">Topics</h1>
        <p class="text-lg text-base-content/70">
          Concrete issues viewed through the lens of the fifteen principles. Each topic
          weaves multiple principles into a coherent position on a real-world concern.
        </p>
      </header>

      <div class="grid sm:grid-cols-2 gap-6">
        {topics.map(topic => (
          <a href={`/topics/${topic.id}`} class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow">
            <div class="card-body">
              <h2 class="card-title font-heading">{topic.data.title}</h2>
              <p class="text-base-content/70">{topic.data.summary}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
