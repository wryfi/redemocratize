---
import ContentLayout from '../../layouts/ContentLayout.astro';
import ContentMeta from '../../components/ContentMeta.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const principles = await getCollection('principles');
  return principles.map(entry => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Principles', url: '/principles' },
  { name: entry.data.title, url: `/principles/${entry.id}` },
];

const definedTerm = {
  name: entry.data.title,
  description: entry.data.summary,
  termCode: String(entry.data.number),
};
---

<ContentLayout
  title={`${entry.data.number}. ${entry.data.title}`}
  description={entry.data.summary}
  headings={headings}
  backLink="/principles"
  backLabel="Back to Principles"
  breadcrumbs={breadcrumbs}
  definedTerm={definedTerm}
>
  <ContentMeta type="principle" />
  <Content />
</ContentLayout>
