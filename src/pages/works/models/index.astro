---
import BaseLayout from "../../../layouts/BaseLayout.astro"
import WorksListing from "../../../components/WorksListing.astro"
import { getCollection } from "astro:content"

let items = []
try {
  items = await getCollection("models", ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true
  })
} catch {}

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Works", url: "/works" },
  { name: "Models", url: "/works/models" },
]
---

<BaseLayout
  title="Models | Democracy Works"
  description="Comparative examples from other democracies that illustrate or inform the Redemocratize principles."
  collectionType="models"
  breadcrumbs={breadcrumbs}
>
  <WorksListing items={items} currentCollection="models" />
</BaseLayout>
