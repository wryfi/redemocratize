---
import BaseLayout from "../../../layouts/BaseLayout.astro"
import WorksListing from "../../../components/WorksListing.astro"
import { getCollection } from "astro:content"

let items = []
try {
  items = await getCollection("articles", ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true
  })
} catch {}

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Works", url: "/works" },
  { name: "Articles", url: "/works/articles" },
]
---

<BaseLayout
  title="Articles | Democracy Works"
  description="Essays and analysis applying the Redemocratize principles to contemporary political and institutional challenges."
  collectionType="articles"
  breadcrumbs={breadcrumbs}
>
  <WorksListing items={items} currentCollection="articles" />
</BaseLayout>
