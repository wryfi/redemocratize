---
import WorksArticleLayout from "../../../layouts/WorksArticleLayout.astro"
import { getCollection, render } from "astro:content"

export async function getStaticPaths() {
  const entries = await getCollection("proposals", ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true
  })
  return entries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }))
}

const statusLabel = {
  draft: "Draft",
  review: "In Review",
  accepted: "Accepted",
}

const { entry } = Astro.props
const { Content, headings } = await render(entry)

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Works", url: "/works" },
  { name: "Proposals", url: "/works/proposals" },
  { name: entry.data.title, url: `/works/proposals/${entry.id}` },
]
---

<WorksArticleLayout
  entry={entry}
  collection="proposals"
  headings={headings}
  breadcrumbs={breadcrumbs}
  status={statusLabel[entry.data.status]}
>
  <Content />
</WorksArticleLayout>
