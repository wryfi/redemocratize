---
import BaseLayout from "../../../layouts/BaseLayout.astro"
import WorksListing from "../../../components/WorksListing.astro"
import { getCollection } from "astro:content"

let items = []
try {
  items = await getCollection("proposals", ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true
  })
} catch {}

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Works", url: "/works" },
  { name: "Proposals", url: "/works/proposals" },
]
---

<BaseLayout
  title="Proposals | Democracy Works"
  description="RFC-style institutional proposals that apply the Redemocratize principles to specific questions of democratic design."
  collectionType="proposals"
  breadcrumbs={breadcrumbs}
>
  <WorksListing items={items} currentCollection="proposals" />
</BaseLayout>
