---
import BaseLayout from "../../layouts/BaseLayout.astro"
import WorksListing from "../../components/WorksListing.astro"
import { COLLECTIONS } from "../../lib/works.js"
import { getCollection } from "astro:content"

let allItems = []
for (const name of COLLECTIONS) {
  try {
    const entries = await getCollection(name, ({ data }) => {
      return import.meta.env.PROD ? data.draft !== true : true
    })
    for (const entry of entries) allItems.push(entry)
  } catch {}
}

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Works", url: "/works" },
]
---

<BaseLayout
  title="Democracy Works"
  description="Essays, topical analysis, institutional proposals, comparative models, and project news — the ongoing work of the Redemocratize project."
  collectionType="works"
  breadcrumbs={breadcrumbs}
>
  <WorksListing items={allItems} currentCollection="all" />
</BaseLayout>
