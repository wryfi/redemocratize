---
import BaseLayout from "../../../layouts/BaseLayout.astro"
import WorksListing from "../../../components/WorksListing.astro"
import { getCollection } from "astro:content"

let items = []
try {
  items = await getCollection("news", ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true
  })
} catch {}

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Works", url: "/works" },
  { name: "News", url: "/works/news" },
]
---

<BaseLayout
  title="News | Democracy Works"
  description="Project updates and news about the development of the Redemocratize framework."
  collectionType="news"
  breadcrumbs={breadcrumbs}
>
  <WorksListing items={items} currentCollection="news" />
</BaseLayout>
