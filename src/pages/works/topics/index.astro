---
import BaseLayout from "../../../layouts/BaseLayout.astro"
import WorksListing from "../../../components/WorksListing.astro"
import { getCollection } from "astro:content"

let items = []
try {
  items = await getCollection("topics", ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true
  })
} catch {}

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Works", url: "/works" },
  { name: "Topics", url: "/works/topics" },
]
---

<BaseLayout
  title="Topics | Democracy Works"
  description="Issue areas mapped to the Redemocratize principles — showing how the framework applies to the problems people care about."
  collectionType="topics"
  breadcrumbs={breadcrumbs}
>
  <WorksListing items={items} currentCollection="topics" />
</BaseLayout>
