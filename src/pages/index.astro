---
import { Image } from "astro:assets"
import BaseLayout from "../layouts/BaseLayout.astro"
import { getCollection } from "astro:content"
import phoenixWings from "../assets/index/phoenix_wings.png"
import decayingCourt from "../assets/index/decaying_court.png"
import architects from "../assets/index/architects.png"
import principlesBg from "../assets/index/principles_bg.png"
import contribute from "../assets/index/contribute.jpg"
import authoritarianism from "../assets/index/authoritarianism.jpg"
import inequality from "../assets/index/inequality.jpg"
import redwoods from "../assets/index/redwoods.jpg"
import adaptiveCapacityImg from "../assets/principles/adaptive_capacity.png"
import subsidiaritySolidarityImg from "../assets/principles/subsidiarity_solidarity.png"
import pluralSovereigntyImg from "../assets/principles/plural_sovereignty.png"
import temporalPluralismImg from "../assets/principles/temporal_pluralism.png"
import epistemicPluralismImg from "../assets/principles/epistemic_pluralism.png"
import universalHumanRightsImg from "../assets/principles/universal_human_rights.png"
import epistemicAutonomyImg from "../assets/principles/epistemic_autonomy.png"
import humanPrimacyImg from "../assets/principles/human_primacy.png"
import economicDemocracyImg from "../assets/principles/economic_democracy.png"
import democraticSovereigntyImg from "../assets/principles/democratic_sovereignty_over_institutions.png"
import inalienableCommonsImg from "../assets/principles/inalienable_commons.png"
import ecologicalEmbeddednessImg from "../assets/principles/ecological_embeddedness.png"
import democraticPeaceSecurityImg from "../assets/principles/democratic_peace_security.png"
import cooperativeSovereigntyImg from "../assets/principles/cooperative_sovereignty.png"
import civicTechnologySovereigntyImg from "../assets/principles/civic_technology_sovereignty.png"

const principleImages = {
  "adaptive-capacity": adaptiveCapacityImg,
  "subsidiarity-solidarity": subsidiaritySolidarityImg,
  "plural-sovereignty": pluralSovereigntyImg,
  "temporal-pluralism": temporalPluralismImg,
  "epistemic-pluralism": epistemicPluralismImg,
  "universal-human-rights": universalHumanRightsImg,
  "epistemic-autonomy": epistemicAutonomyImg,
  "human-primacy": humanPrimacyImg,
  "economic-democracy": economicDemocracyImg,
  "democratic-sovereignty-over-institutions": democraticSovereigntyImg,
  "inalienable-commons": inalienableCommonsImg,
  "ecological-embeddedness": ecologicalEmbeddednessImg,
  "democratic-peace-and-security": democraticPeaceSecurityImg,
  "cooperative-sovereignty": cooperativeSovereigntyImg,
  "civic-technology-sovereignty": civicTechnologySovereigntyImg,
}

let topics = []
try {
  topics = await getCollection("topics")
} catch {}

const principles = (await getCollection("principles")).sort((a, b) => a.data.number - b.data.number)
const structural = principles.filter((p) => p.data.tier === "structural")
const substantive = principles.filter((p) => p.data.tier === "substantive")
---

<BaseLayout>
  <!-- Hero -->
  <section
    class="hero-section relative overflow-hidden min-h-[calc(100vh-4rem)] flex items-center"
  >
    <Image
      src={phoenixWings}
      alt=""
      widths={[800, 1200, 1920]}
      class="parallax-bg absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-base-100/88 dark:bg-base-100/75"></div>
    <div class="container max-w-4xl relative">
      <!-- Masthead -->
      <div class="flex items-start gap-5 md:gap-8 lg:gap-10 mb-10 lg:mb-14">
        <img
          src="/favicon.svg"
          alt=""
          class="hero-logo w-20 h-20 md:w-28 md:h-28 lg:w-40 lg:h-40 xl:w-44 xl:h-44 shrink-0"
        />
        <div>
          <h1 class="text-3xl md:text-4xl lg:text-6xl xl:text-7xl font-bold font-heading tracking-tight">
            Redemocratize
          </h1>
          <p class="text-base md:text-lg lg:text-2xl italic text-base-content/70 mt-2 lg:mt-3 leading-snug">
            Envisioning Resilient Democracy
          </p>
          <p
            class="text-base md:text-lg lg:text-2xl italic text-base-content/70 mt-0.5 leading-snug"
          >
            In the Open, For the Living
          </p>
        </div>
      </div>

      <!-- Rule -->
      <div class="hero-rule h-px mb-8 md:mb-12 lg:mb-14"></div>

      <!-- Manifesto -->
      <div class="text-base md:text-xl lg:text-2xl space-y-3 lg:space-y-4 text-base-content/85">
        <p>
          Democratic governance is under assault everywhere, but
          <em>democracy</em> is not the problem.
        </p>
        <p>The problem is institutional vulnerability to capture.</p>
        <p>We know what's breaking. The harder question is: how do we rebuild?</p>
        <p>Constitutions designed to resist change cannot resist capture.</p>
        <p>Redemocratize offers resilient principles for the world we actually inhabit.</p>
        <p class="font-semibold text-base-content">
          The answer to capture is not resistance. It's better design.
        </p>
      </div>
    </div>

    <a href="#the-problem" class="hero-scroll-cue" aria-label="Scroll to The Problem">
      <span>Read on</span>
      <svg
        width="14"
        height="22"
        viewBox="0 0 14 22"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        aria-hidden="true"
      >
        <path d="M7 1v18M1 14l6 6 6-6" stroke-linecap="square" />
      </svg>
    </a>
  </section>

  <!-- The Problem -->
  <section id="the-problem" class="py-20 lg:py-28 bg-base-200">
    <div class="container max-w-5xl">
      <header class="mb-12 lg:mb-16">
        <p class="eyebrow section-eyebrow-error mb-4">The Diagnosis</p>
        <h2
          class="text-4xl lg:text-5xl font-bold font-heading tracking-tight leading-[1.05]"
        >
          The Problem
        </h2>
      </header>
      <div class="flex flex-col lg:flex-row lg:items-center gap-10 lg:gap-14">
        <!-- Window -->
        <div class="lg:w-2/5 shrink-0">
          <div class="rounded-lg overflow-hidden shadow-lg aspect-[3/4]">
            <Image
              src={decayingCourt}
              alt="Cracked facade of a marble courthouse"
              widths={[600, 900]}
              class="parallax-window-img w-[300%] max-w-none -ml-[100%]"
              loading="lazy"
            />
          </div>
        </div>
        <!-- Text -->
        <div class="prose prose-lg max-w-none">
          <p>
            The crisis is not one failure. It is an accumulation, with each structural breakdown
            creating the conditions for the next, built on constitutional designs that were never
            able to correct themselves.
          </p>
          <p>
            Across democracies, concentrated wealth has moved into structures that founders left
            unguarded, using the tools of democratic governance to ensure it cannot be dislodged.
            Amendment processes were made deliberately difficult, protecting the advantages of those
            who demanded them. These failures are neither accident nor conspiracy. They are the
            predictable result of constitutional designs that assumed good faith, relied on norms
            instead of structure, and provided no realistic mechanism for their own renewal.
          </p>
          <p>
            The 21st century has compounded the crisis with threats no earlier framework could have
            anticipated: industrialized manipulation of the information environment, AI-generated
            disinformation at scale, corporate-authoritarian alignment, automated surveillance, the
            enclosure of shared wealth by a shrinking oligarchic class, and ecological breakdown
            that existing systems have no structural capacity to address.
          </p>
          <p>
            The present moment does not demand that we abandon democracy. It demands that we build
            democratic institutions robust to the world we actually inhabit.
          </p>
          <div class="mt-8 not-prose">
            <a href="/works/articles/cumulative-crises" class="arrow-link">
              <span>The cumulative crises</span>
              <svg
                width="24"
                height="10"
                viewBox="0 0 24 10"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                aria-hidden="true"
              >
                <path d="M0 5h22M17 1l5 4-5 4" stroke-linecap="square" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Approach -->
  <section class="py-20 lg:py-24 relative overflow-hidden min-h-[50vh] flex items-center">
    <Image
      src={architects}
      alt=""
      widths={[800, 1200, 1920]}
      class="parallax-bg absolute inset-0 w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-base-100/88 dark:bg-base-100/80"></div>
    <div class="container max-w-4xl relative">
      <header class="mb-10 lg:mb-14">
        <p class="eyebrow section-eyebrow-primary mb-4">The Method</p>
        <h2
          class="text-4xl lg:text-5xl font-bold font-heading tracking-tight leading-[1.05]"
        >
          Our Approach
        </h2>
      </header>
      <div class="prose prose-lg max-w-none backdrop-blur-xs">
        <p>Redemocratize articulates capture-resistant design principles for modern democracy.</p>
        <p>
          The framework addresses problems that existing constitutions were not designed for:
          algorithmic manipulation of public discourse, the concentration of epistemic power in
          unaccountable private hands, automated systems making decisions about human rights,
          extreme wealth that negates democratic self-governance, ecological limits that no
          political arrangement can override, and institutional capture by actors who use the tools
          of democracy to dismantle it.
        </p>
        <p>
          The principles function as architectural elements around which resilient government
          institutions may be constructed. We evaluate institutional forms by how well they serve
          the principles, not by how closely they resemble what exists.
        </p>
        <p>
          We invite collaborators to apply these design principles to specific governance challenges
          and the creation of new democratic forms, and provide infrastructure and support for the
          work of building functional democracy.
        </p>
        <p>
          This is closer to an open-source software project than a political campaign. The
          principles are developed in the open. Contributions are encouraged. Everything is
          versioned, transparent, and revisable — because a project advocating for adaptive
          governance must first practice it.
        </p>
        <p>We are just getting started, but we are building in the open.</p>
        <p>
          You are invited to <a href="/contribute">join us</a> in ensuring that government of the people,
          by the people, for the people does not perish from the earth.
        </p>
      </div>
    </div>
  </section>

  <!-- Fifteen Principles -->
  <section class="py-20 lg:py-28 bg-base-200 relative overflow-hidden">
    <Image
      src={principlesBg}
      alt=""
      widths={[800, 1200, 1920]}
      class="principles-bg absolute inset-0 w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-base-200/80 dark:bg-base-200/85"></div>
    <div class="container max-w-6xl relative">
      <header class="mb-14 lg:mb-20 max-w-3xl">
        <p class="eyebrow section-eyebrow-primary mb-4">The Fifteen</p>
        <h2
          class="text-4xl lg:text-6xl font-bold font-heading tracking-tight leading-[1] mb-6"
        >
          The Redemocratize Principles
        </h2>
        <p class="text-lg lg:text-xl text-base-content/70 leading-relaxed">
          Read them as a system, not a list. Five structural principles shape how
          governance is organized; ten substantive commitments define what it must
          protect. The tension between the two tiers is productive, and must be
          held.
        </p>
      </header>

      <!-- Desktop: 5x3 grid of flip cards -->
      <div class="hidden md:grid md:grid-cols-3 gap-5 lg:gap-6">
        {
          principles.map((p) => {
            const isStructural = p.data.tier === "structural"
            const label = isStructural ? "Structure" : "Protection"
            const borderColor = isStructural ? "border-primary" : "border-error"
            const badgeColor = isStructural ? "badge-primary" : "badge-error"
            const cardImg = principleImages[p.id]
            return (
              <a href={`/principles/${p.id}`} class="principle-card-link">
                <div class={`principle-card ${borderColor}`}>
                  <div class="principle-card-inner">
                    <div class="principle-card-front">
                      <div class="relative aspect-[3/4] lg:aspect-[5/4] overflow-hidden">
                        {cardImg && (
                          <Image
                            src={cardImg}
                            alt=""
                            widths={[300, 450]}
                            class="absolute inset-0 w-full h-full object-cover"
                          />
                        )}
                        <span
                          class={`badge badge-sm ${badgeColor} font-heading absolute top-3 left-3 z-10`}
                        >
                          {label}
                        </span>
                      </div>
                      <div
                        class={`px-3 py-3 ${isStructural ? "bg-primary" : "bg-error"}`}
                      >
                        <h3 class="text-base lg:text-lg font-bold font-heading text-center text-white leading-tight">
                          {p.data.title}
                        </h3>
                      </div>
                    </div>
                    <div class="principle-card-back">
                      <p class="text-sm text-center leading-snug">{p.data.summary}</p>
                    </div>
                  </div>
                </div>
              </a>
            )
          })
        }
      </div>

      <!-- Mobile: carousel -->
      <div class="md:hidden carousel carousel-center w-full gap-4 px-2">
        {
          principles.map((p) => {
            const isStructural = p.data.tier === "structural"
            const label = isStructural ? "Structure" : "Protection"
            const borderColor = isStructural ? "border-primary" : "border-error"
            const badgeColor = isStructural ? "badge-primary" : "badge-error"
            const cardImg = principleImages[p.id]
            return (
              <div class="carousel-item">
                <div class={`principle-card w-56 ${borderColor}`}>
                  <div class="principle-card-inner">
                    <div class="principle-card-front">
                      <div class="relative aspect-[3/4] overflow-hidden">
                        {cardImg && (
                          <Image
                            src={cardImg}
                            alt=""
                            widths={[250]}
                            class="absolute inset-0 w-full h-full object-cover"
                          />
                        )}
                        <span
                          class={`badge badge-sm ${badgeColor} font-heading absolute top-3 left-3 z-10`}
                        >
                          {label}
                        </span>
                      </div>
                      <div
                        class={`px-3 py-3 ${isStructural ? "bg-primary" : "bg-error"}`}
                      >
                        <h3 class="text-base font-bold font-heading text-center text-white leading-tight">
                          {p.data.title}
                        </h3>
                      </div>
                    </div>
                    <div class="principle-card-back">
                      <p class="text-sm text-center leading-snug">{p.data.summary}</p>
                      <a
                        href={`/principles/${p.id}`}
                        class="btn btn-sm btn-outline btn-primary font-heading mt-3"
                      >
                        Read more
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            )
          })
        }
      </div>

      <div class="mt-14 lg:mt-20 flex justify-center">
        <a
          href="/principles"
          class="btn btn-primary btn-lg font-heading tracking-wide"
        >
          Explore the Principles
        </a>
      </div>
    </div>
  </section>

  <!-- What We Build On -->
  <section class="py-20 lg:py-24 relative overflow-hidden min-h-[50vh] flex items-center">
    <Image
      src={redwoods}
      alt=""
      widths={[800, 1200, 1920]}
      class="parallax-bg absolute inset-0 w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-base-100/88 dark:bg-base-100/80"></div>
    <div class="container max-w-4xl relative text-black dark:text-base-content">
      <header class="mb-10 lg:mb-14">
        <p class="eyebrow section-eyebrow-primary mb-4">The Inheritance</p>
        <h2
          class="text-4xl lg:text-5xl font-bold font-heading tracking-tight leading-[1.05]"
        >
          On the Shoulders of Giants
        </h2>
      </header>
      <div class="prose prose-lg max-w-none text-black dark:text-base-content backdrop-blur-xs">
        <p>
          This project is not nihilistic about existing democratic traditions. Many principles
          embedded in those traditions are sound — due process, freedom of conscience, separation of
          powers, civilian control of the military, the rejection of hereditary privilege. The
          crisis is that institutional implementations have failed these principles.
        </p>
        <p>
          We claim these traditions more seriously than those defending the status quo. We insist on
          fulfilling what they promised but could not deliver.
        </p>
      </div>
      <div class="mt-10">
        <a href="/works/articles/inherited-principles" class="arrow-link">
          <span>Inherited principles</span>
          <svg
            width="24"
            height="10"
            viewBox="0 0 24 10"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            aria-hidden="true"
          >
            <path d="M0 5h22M17 1l5 4-5 4" stroke-linecap="square" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Start Here -->
  <section class="py-20 lg:py-28 bg-base-200">
    <div class="container max-w-5xl">
      <header class="mb-12 lg:mb-16 max-w-3xl">
        <p class="eyebrow section-eyebrow-error mb-4">In Practice</p>
        <h2
          class="text-4xl lg:text-5xl font-bold font-heading tracking-tight leading-[1.05] mb-6"
        >
          The Principles Applied
        </h2>
        <p class="text-lg text-base-content/70 leading-relaxed">
          The principles are the intellectual architecture. Most people think in
          terms of issues. These topic pages show how the principles apply to the
          things you care about.
        </p>
      </header>

      <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
        <a href="/works/topics/authoritarianism" class="topic-card">
          <div class="topic-card-image">
            <Image
              src={authoritarianism}
              alt="Riot police in formation"
              widths={[400, 600]}
              loading="lazy"
            />
          </div>
          <div class="topic-card-body">
            <h3 class="topic-card-title">
              Preventing &amp; Defeating Authoritarianism
            </h3>
            <p class="topic-card-summary">
              How the entire framework is designed to make authoritarian capture
              structurally impossible.
            </p>
            <span class="topic-card-arrow">
              <span>Read the topic</span>
              <svg
                width="22"
                height="10"
                viewBox="0 0 22 10"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                aria-hidden="true"
              >
                <path d="M0 5h20M15 1l5 4-5 4" stroke-linecap="square" />
              </svg>
            </span>
          </div>
        </a>

        <a href="/works/topics/wealth-inequality" class="topic-card">
          <div class="topic-card-image">
            <Image
              src={inequality}
              alt="Homeless encampment on a city street"
              widths={[400, 600]}
              class="object-bottom"
              loading="lazy"
            />
          </div>
          <div class="topic-card-body">
            <h3 class="topic-card-title">Wealth Inequality &amp; Oligarchy</h3>
            <p class="topic-card-summary">
              Why extreme wealth concentration is inherently incompatible with
              democracy, and what governance designed to prevent it looks like.
            </p>
            <span class="topic-card-arrow">
              <span>Read the topic</span>
              <svg
                width="22"
                height="10"
                viewBox="0 0 22 10"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                aria-hidden="true"
              >
                <path d="M0 5h20M15 1l5 4-5 4" stroke-linecap="square" />
              </svg>
            </span>
          </div>
        </a>
      </div>

      <p class="mt-10 text-sm text-base-content/60">
        Help us develop: Education, Immigration, Healthcare, Criminal Justice,
        Climate &amp; Environment, Labor &amp; Work, Technology &amp; Privacy,
        Money &amp; Politics.
      </p>

      <div class="mt-8">
        <a href="/works" class="arrow-link">
          <span>Democracy Works</span>
          <svg
            width="24"
            height="10"
            viewBox="0 0 24 10"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            aria-hidden="true"
          >
            <path d="M0 5h22M17 1l5 4-5 4" stroke-linecap="square" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Contribute -->
  <section class="py-20 lg:py-24 relative overflow-hidden min-h-[50vh] flex items-center">
    <Image
      src={contribute}
      alt=""
      widths={[800, 1200, 1920]}
      class="parallax-bg absolute inset-0 w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-base-100/88 dark:bg-base-100/80"></div>
    <div class="container max-w-4xl relative">
      <header class="mb-10 lg:mb-14">
        <p class="eyebrow section-eyebrow-primary mb-4">Open Source</p>
        <h2
          class="text-4xl lg:text-5xl font-bold font-heading tracking-tight leading-[1.05]"
        >
          Contribute
        </h2>
      </header>
      <div class="prose prose-lg max-w-none backdrop-blur-xs">
        <p>
          This is an open project. The principles are developed in the open and contributions are
          welcome from anyone — scholars, organizers, lawyers, technologists, citizens.
        </p>
        <p>
          You can contribute essays and analysis on how the principles apply to issues you know. You
          can propose institutional mechanisms that serve the principles. You can bring comparative
          examples from other democratic traditions. You can translate.
        </p>
        <p>
          The preferred way to contribute is through git and the project's source repository, but we
          also accept contributions through Google Docs. All content is licensed CC BY-SA.
        </p>
      </div>
      <div class="mt-10">
        <a href="/contribute" class="arrow-link">
          <span>How to contribute</span>
          <svg
            width="24"
            height="10"
            viewBox="0 0 24 10"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            aria-hidden="true"
          >
            <path d="M0 5h22M17 1l5 4-5 4" stroke-linecap="square" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Stay Connected -->
  <section class="py-20 lg:py-28">
    <div class="container max-w-4xl text-center">
      <header class="mb-10 lg:mb-14">
        <p class="eyebrow mb-4">Stay Connected</p>
        <h2
          class="text-4xl lg:text-5xl font-bold font-heading tracking-tight leading-[1.05] mb-5"
        >
          Join the mailing list
        </h2>
        <p class="text-lg text-base-content/70 leading-relaxed max-w-xl mx-auto">
          Follow the project's development and get notified of new content and
          opportunities to contribute.
        </p>
      </header>
      <form id="subscribe-form" class="flex flex-col items-center gap-4">
        <div class="join">
          <input
            type="email"
            id="subscribe-email"
            placeholder="your@email.com"
            class="input join-item w-64"
            required
            pattern="[^@\s]+@[^@\s]+\.[^@\s]+"
            title="Please enter a valid email address"
          />
          <button type="submit" class="btn btn-primary join-item font-heading">Subscribe</button>
        </div>
        <div class="cf-turnstile" data-sitekey="0x4AAAAAACwW6ap8A70BtVeG" data-theme="auto"></div>
      </form>
      <p id="subscribe-message" class="mt-4 text-sm hidden"></p>
    </div>
  </section>

  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

  <script>
    const form = document.getElementById("subscribe-form")
    const emailInput = document.getElementById("subscribe-email")
    const message = document.getElementById("subscribe-message")

    form.addEventListener("submit", async (e) => {
      e.preventDefault()
      const email = emailInput.value.trim()
      if (!email) return

      const turnstileToken = form.querySelector("[name='cf-turnstile-response']")?.value
      if (!turnstileToken) {
        message.textContent = "Please complete the verification."
        message.className = "mt-4 text-sm text-error"
        return
      }

      const button = form.querySelector("button")
      button.disabled = true
      button.textContent = "Subscribing..."
      message.classList.add("hidden")

      try {
        const res = await fetch("/api/subscribe", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email, turnstileToken }),
        })

        const data = await res.json().catch(() => null)

        if (res.ok) {
          message.textContent = "Check your email to confirm your subscription."
          message.className = "mt-4 text-sm text-success"
          emailInput.value = ""
          turnstile.reset()
        } else {
          message.textContent = data?.message || "Something went wrong. Please try again."
          message.className = "mt-4 text-sm text-error"
        }
      } catch {
        message.textContent = "Could not reach the server. Please try again later."
        message.className = "mt-4 text-sm text-error"
      } finally {
        button.disabled = false
        button.textContent = "Subscribe"
      }
    })
  </script>

  <style>
    /* Principles section background — static, faded top/bottom */
