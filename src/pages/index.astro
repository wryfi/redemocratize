    .principle-card {
      perspective: 800px;
      cursor: pointer;
      border-width: 2px;
      border-style: solid;
      border-radius: var(--radius-box);
      background: var(--color-base-100);
      /* Fill the flex/grid cell. In the mobile carousel the items are
         stretched to the tallest card's height; without this the card
         sizes to its intrinsic content and leaves a band of bg-base-100
         between the label and the bottom border. */
      height: 100%;
      overflow: hidden;
    }

    /* Dark mode: tone down the image area so cards don't glow */
    @media (prefers-color-scheme: dark) {
      .principle-card-front > div:first-child::after {
        content: "";
        position: absolute;
        inset: 0;
        background: rgba(20, 20, 24, 0.4);
        pointer-events: none;
        z-index: 1;
      }
      /* Mute the card borders so they sit back against the dark canvas */
      .principle-card.border-primary {
        border-color: oklch(44% 0.075 237);
      }
      .principle-card.border-error {
        border-color: oklch(50% 0.13 27);
      }
      /* Dim the colored title bars: darker, less saturated, hue preserved */
      .principle-card-front .bg-primary {
        background-color: oklch(40% 0.08 237);
      }
      .principle-card-front .bg-error {
        background-color: oklch(46% 0.13 27);
      }
    }

    .principle-card-inner {
      position: relative;
      width: 100%;
      /* Fill the card: the carousel stretches all items to the tallest
         card's height, so without this the inner collapses to its
         intrinsic content size and exposes the card's bg-base-100
         between the label and the bottom border. */
      height: 100%;
      transition: transform 0.5s ease;
      transform-style: preserve-3d;
    }

    .principle-card:hover .principle-card-inner {
      transform: rotateY(180deg);
    }

    .principle-card-front {
      position: relative;
      -webkit-backface-visibility: hidden;
      backface-visibility: hidden;
      display: flex;
      flex-direction: column;
      height: 100%;
    }
    /* Image area grows to consume any extra card height; the label
       (last child) stays pinned to the bottom edge. */
    .principle-card-front > div:first-child {
      flex: 1 1 auto;
      min-height: 0;
    }

    .principle-card-back {
      position: absolute;
      inset: 0;
      -webkit-backface-visibility: hidden;
      backface-visibility: hidden;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 1.25rem;
      transform: rotateY(180deg);
    }

    /* iOS Safari fix: hide front face when card is flipped */
    .principle-card.flipped .principle-card-front {
      visibility: hidden;
    }
    .principle-card.flipped .principle-card-back {
      visibility: visible;
    }

    /* Mobile: tap to flip */
    @media (hover: none) {
      .principle-card.flipped .principle-card-inner {
        transform: rotateY(180deg);
      }
      .principle-card:hover .principle-card-inner {
        transform: none;
      }
      .principle-card.flipped:hover .principle-card-inner {
        transform: rotateY(180deg);
      }
    }
  </style>

  <script>
    // Mobile tap-to-flip for principle cards
    if (window.matchMedia("(hover: none)").matches) {
      document.querySelectorAll(".principle-card").forEach((card) => {
        card.addEventListener("click", (e) => {
          if (e.target.closest("a")) return
          card.classList.toggle("flipped")
        })
      })
    }
  </script>

  <script>
    const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent)

    if (!isMobile) {
      const bgImages = document.querySelectorAll(".parallax-bg")
      const windowImages = document.querySelectorAll(".parallax-window-img")
      let ticking = false

      function updateParallax() {
        const vh = window.innerHeight

        bgImages.forEach((img) => {
          const section = img.closest("section")
          const rect = section.getBoundingClientRect()
          const progress = (rect.top + rect.height) / (vh + rect.height)
          const position = 30 + progress * 40
          img.style.objectPosition = `center ${position}%`
        })

        windowImages.forEach((img) => {
          const container = img.parentElement
          const rect = container.getBoundingClientRect()
          const containerHeight = rect.height
          const imgHeight = img.offsetHeight
          const travel = imgHeight - containerHeight
          const progress = (rect.top + containerHeight) / (vh + containerHeight)
          const offset = -(1 - progress) * travel
          img.style.transform = `translateY(${offset}px)`
        })
      }

      updateParallax()

      window.addEventListener("scroll", () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            updateParallax()
            ticking = false
          })
          ticking = true
        }
      })
    }
  </script>
</BaseLayout>
