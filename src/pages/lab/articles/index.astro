---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import LabsItemCard from '../../../components/LabsItemCard.astro';
import { getCollection } from 'astro:content';

const COLLECTIONS = ['articles', 'topics', 'proposals', 'models', 'news'];
const collectionLabel = {
  articles: 'article',
  topics: 'topic',
  proposals: 'proposal',
  models: 'model',
  news: 'news',
};

const currentCollection = 'articles';

let entries = [];
try {
  entries = await getCollection(currentCollection, ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  });
} catch {}

const pinned = entries
  .filter(e => e.data.pin != null)
  .sort((a, b) => a.data.pin - b.data.pin);
const unpinned = entries
  .filter(e => e.data.pin == null)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const items = [...pinned, ...unpinned];
---

<BaseLayout title="Articles | Redemocratize Laboratory">
  <div class="bg-base-200 min-h-screen">
  <div class="container py-8">
    <div class="max-w-4xl mx-auto">
      <header class="mb-12">
        <h1 class="text-4xl lg:text-5xl font-bold font-heading mb-4">Redemocratize Laboratory</h1>
        <p class="text-lg text-base-content/70">
          Topics, proposals, models, articles, and news from the Redemocratize project.
        </p>
      </header>

      <div class="flex flex-wrap gap-2 mb-10">
        <a href="/lab" class="btn btn-sm btn-outline">All</a>
        {COLLECTIONS.map(name => (
          <a
            href={`/lab/${name}`}
            class={`btn btn-sm ${name === currentCollection ? 'btn-primary' : 'btn-outline'}`}
          >
            {collectionLabel[name]}
          </a>
        ))}
      </div>

      <div class="space-y-6">
        {items.map(entry => (
          <LabsItemCard item={entry} collection={currentCollection} />
        ))}
      </div>

      {items.length === 0 && (
        <div class="text-center py-16 text-base-content/50">
          <p class="text-lg">No articles yet. Check back soon.</p>
        </div>
      )}
    </div>
  </div>
  </div>
</BaseLayout>
