---
import { siteConfig } from '../config/site.js';

const {
  title = siteConfig.name,
  description = siteConfig.description,
  image = siteConfig.defaultImage,
  canonical,
  type = 'website',
  faqs,
  author,
  breadcrumbs,
  collectionType,
  definedTerm,
  definedTermSet,
} = Astro.props;

const siteUrl = siteConfig.url;
const licenseUrl = siteConfig.license.url;
const fullTitle = title === siteConfig.name || title.includes(siteConfig.name)
  ? title
  : `${title} | ${siteConfig.name}`;
const imageUrl = new URL(image, siteUrl).href;
const pageUrl = canonical || Astro.url.href;
const isHomepage = Astro.url.pathname === '/';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteConfig.name,
  url: siteUrl,
  logo: new URL('/favicon.svg', siteUrl).href,
  description: siteConfig.description,
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteConfig.name,
  url: siteUrl,
  description: siteConfig.description,
  license: licenseUrl,
};

const faqSchema = faqs && faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
} : null;

const articleSchema = type === 'article' ? {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  image: imageUrl,
  url: pageUrl,
  license: licenseUrl,
  ...(author && {
    author: {
      '@type': 'Person',
      name: author,
    },
  }),
  publisher: {
    '@type': 'Organization',
    name: siteConfig.name,
    logo: {
      '@type': 'ImageObject',
      url: new URL('/favicon.svg', siteUrl).href,
    },
  },
} : null;

const breadcrumbSchema = breadcrumbs && breadcrumbs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((crumb, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: crumb.name,
    item: new URL(crumb.url, siteUrl).href,
  })),
} : null;

const collectionSchema = collectionType ? {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: fullTitle,
  description: description,
  url: pageUrl,
} : null;

const definedTermSchema = definedTerm ? {
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  name: definedTerm.name,
  description: definedTerm.description,
  url: pageUrl,
  license: licenseUrl,
  ...(definedTerm.termCode && { termCode: definedTerm.termCode }),
  inDefinedTermSet: new URL('/principles', siteUrl).href,
} : null;

const definedTermSetSchema = definedTermSet && definedTermSet.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'DefinedTermSet',
  name: 'The Redemocratize Principles',
  description: 'Fifteen design principles for democratic governance adequate to the 21st century.',
  url: pageUrl,
  license: licenseUrl,
  hasDefinedTerm: definedTermSet.map((term) => ({
    '@type': 'DefinedTerm',
    name: term.name,
    description: term.description,
    url: new URL(term.url, siteUrl).href,
    ...(term.termCode && { termCode: term.termCode }),
  })),
} : null;
---

<meta property="og:site_name" content={siteConfig.name} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="Redemocratize — design principles for democratic self-governance" />
<meta property="og:type" content={type} />
<meta property="og:url" content={pageUrl} />
<meta property="og:locale" content="en_US" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
<meta name="twitter:image:alt" content="Redemocratize — design principles for democratic self-governance" />

<link rel="canonical" href={pageUrl} />

{isHomepage && (
  <>
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  </>
)}
{articleSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
)}
{faqSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
)}
{breadcrumbSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
)}
{collectionSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
)}
{definedTermSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(definedTermSchema)} />
)}
{definedTermSetSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(definedTermSetSchema)} />
)}
