---
const { item, collection } = Astro.props;

const collectionLabel = {
  articles: 'article',
  topics: 'topic',
  proposals: 'proposal',
  models: 'model',
  news: 'news',
};
const collectionColor = {
  articles: 'badge-primary',
  topics: 'badge-accent',
  proposals: 'badge-info',
  models: 'badge-success',
  news: 'badge-warning',
};

function formatDate(date) {
  return new Date(date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

function getExcerpt(body, maxLength = 200) {
  if (!body) return '';
  const cleaned = body
    .replace(/^import\s+.+$/gm, '')
    .replace(/<[^>]+\/>/g, '')
    .replace(/<[^>]+>[\s\S]*?<\/[^>]+>/g, '')
    .replace(/^---[\s\S]*?---/m, '')
    .replace(/^#+\s+.+$/gm, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[_*`~]/g, '')
    .trim();
  const firstParagraph = cleaned.split(/\n\n+/).find(p => p.trim().length > 0) || '';
  if (firstParagraph.length <= maxLength) return firstParagraph;
  return firstParagraph.slice(0, maxLength).replace(/\s+\S*$/, '') + '...';
}

const col = collection;
---

<a
  href={`/lab/${col}/${item.id}`}
  class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow block"
>
  <div class="card-body p-5">
    <div class="flex items-center gap-3 mb-1">
      {item.data.pin != null && (
        <span class="badge badge-neutral badge-sm">pinned</span>
      )}
      <span class={`badge badge-sm ${collectionColor[col]}`}>
        {collectionLabel[col]}
      </span>
      <span class="text-xs text-base-content/50">
        {formatDate(item.data.pubDate)}
      </span>
      {item.data.draft && (
        <span class="badge badge-ghost badge-sm">draft</span>
      )}
    </div>
    <h2 class="card-title font-heading text-lg">{item.data.title}</h2>
    <p class="text-base-content/70 text-sm">
      {item.data.summary || getExcerpt(item.body)}
    </p>
    {item.data.author && (
      <p class="text-xs text-base-content/40 mt-1">by {item.data.author}</p>
    )}
  </div>
</a>
