---
const { headings } = Astro.props;
---

{headings && headings.length > 0 && (
  <div
    class="lg:hidden sticky top-16 z-40 bg-base-200/95 backdrop-blur-sm
           border-b border-base-300"
    id="mobile-toc"
  >
    <button
      class="w-full flex items-center justify-between px-4 py-2.5
             text-sm font-heading"
      id="mobile-toc-toggle"
      aria-expanded="false"
      aria-controls="mobile-toc-panel"
    >
      <span class="flex items-center gap-2 min-w-0">
        <span class="text-primary font-semibold shrink-0">&#167;</span>
        <span
          class="truncate text-base-content/70"
          id="mobile-toc-current"
        >
          Table of Contents
        </span>
      </span>
      <svg
        class="w-4 h-4 shrink-0 text-base-content/50 transition-transform
               duration-200"
        id="mobile-toc-chevron"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M19 9l-7 7-7-7"
        />
      </svg>
    </button>

    <nav
      class="hidden overflow-y-auto max-h-[60vh] px-4 pb-3"
      id="mobile-toc-panel"
      aria-label="Table of Contents"
    >
      <ul class="space-y-1">
        {headings.map((heading) => (
          <li>
            <a
              href={`#${heading.slug}`}
              class={`mobile-toc-link block py-1.5 transition-colors
                      hover:text-primary ${
                heading.depth === 2
                  ? 'font-semibold text-sm'
                  : 'text-base-content/70 text-xs pl-4'
              }`}
              data-heading={heading.slug}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
)}

<script>
  function initMobileToc() {
    const toggle = document.getElementById('mobile-toc-toggle');
    const panel = document.getElementById('mobile-toc-panel');
    const chevron = document.getElementById('mobile-toc-chevron');
    const currentLabel = document.getElementById('mobile-toc-current');
    const tocLinks = document.querySelectorAll('.mobile-toc-link');

    if (!toggle || !panel || !tocLinks.length) return;

    // Toggle expand/collapse
    let expanded = false;

    function setExpanded(value) {
      expanded = value;
      panel.classList.toggle('hidden', !expanded);
      toggle.setAttribute('aria-expanded', String(expanded));
      chevron?.classList.toggle('rotate-180', expanded);
    }

    toggle.addEventListener('click', () => setExpanded(!expanded));

    // Close panel when a link is tapped
    tocLinks.forEach(link => {
      link.addEventListener('click', () => setExpanded(false));
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      const container = document.getElementById('mobile-toc');
      if (expanded && container && !container.contains(e.target)) {
        setExpanded(false);
      }
    });

    // Scroll tracking
    const slugs = Array.from(tocLinks).map(
      link => link.dataset.heading
    );
    const headingElements = slugs
      .map(slug => document.getElementById(slug))
      .filter(Boolean);

    if (!headingElements.length) return;

    let activeSlug = null;

    function setActive(slug) {
      if (slug === activeSlug) return;
      activeSlug = slug;

      // Update the current section label
      const activeLink = Array.from(tocLinks).find(
        l => l.dataset.heading === slug
      );
      if (activeLink && currentLabel) {
        currentLabel.textContent = activeLink.textContent.trim();
      }

      // Highlight active link in the expanded panel
      tocLinks.forEach(link => {
        if (link.dataset.heading === slug) {
          link.classList.add('text-primary');
        } else {
          link.classList.remove('text-primary');
        }
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter(e => e.isIntersecting)
          .sort(
            (a, b) =>
              a.boundingClientRect.top - b.boundingClientRect.top
          );

        if (visible.length > 0) {
          setActive(visible[0].target.id);
        } else {
          let lastAbove = null;
          for (const el of headingElements) {
            if (el.getBoundingClientRect().top < 120) {
              lastAbove = el;
            }
          }
          if (lastAbove) {
            setActive(lastAbove.id);
          }
        }
      },
      { rootMargin: '-100px 0px -60% 0px', threshold: 0 }
    );

    headingElements.forEach(el => observer.observe(el));
  }

  initMobileToc();
  document.addEventListener('astro:after-swap', initMobileToc);
</script>
