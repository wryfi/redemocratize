---
import { Icon } from 'astro-icon/components';

const { author } = Astro.props;
const attribution = author
  ? `${author}, Redemocratize Project`
  : 'Redemocratize Project contributors';
---

<button
  type="button"
  class="badge badge-md cursor-pointer hover:brightness-95 transition-all gap-1 bg-badge-license text-badge-license-content license-badge-trigger"
  title="Licensed under CC BY-SA 4.0"
>
  <Icon name="ph:scales-bold" class="size-4" />
  CC BY-SA
</button>

<dialog class="modal license-modal">
  <div class="modal-box max-w-md">
    <form method="dialog">
      <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2" aria-label="Close">&#x2715;</button>
    </form>
    <div class="flex items-start gap-4">
      <img
        src="/images/cc-by-sa.svg"
        alt="CC BY-SA 4.0"
        width="88"
        height="31"
        class="shrink-0 mt-1"
      />
      <div>
        <h3 class="font-bold text-lg">License</h3>
        <p class="text-sm text-base-content/70 mt-2">
          &copy; {attribution}.
        </p>
        <p class="text-sm text-base-content/70 mt-2">
          This work is licensed under a
          <a
            href="https://creativecommons.org/licenses/by-sa/4.0/"
            target="_blank"
            rel="noopener noreferrer license"
            class="link link-primary"
          >Creative Commons Attribution-ShareAlike 4.0
          International License</a>.
        </p>
        <p class="text-sm text-base-content/70 mt-2">
          When sharing or adapting, please attribute to
          <strong>{attribution}</strong>
          (<a href="https://redemocratize.org" class="link link-primary">redemocratize.org</a>).
        </p>
      </div>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button aria-label="Close">close</button>
  </form>
</dialog>

<script>
  // Wire up each trigger to its following <dialog> sibling. Works regardless
  // of where the component is nested in the page.
  function initLicenseBadges() {
    document.querySelectorAll('.license-badge-trigger').forEach((btn) => {
      if (btn.dataset.licenseWired === '1') return;
      btn.dataset.licenseWired = '1';
      btn.addEventListener('click', () => {
        let el = btn.nextElementSibling;
        while (el && !el.matches?.('dialog.license-modal')) {
          el = el.nextElementSibling;
        }
        if (el && typeof el.showModal === 'function') {
          el.showModal();
        }
      });
    });
  }
  initLicenseBadges();
  document.addEventListener('astro:after-swap', initLicenseBadges);
</script>
