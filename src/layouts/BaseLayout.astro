---
import "../styles/app.css"
import { Font } from "astro:assets"
import Navigation from "../components/Navigation.astro"
import SEO from "../components/SEO.astro"
import { siteConfig } from "../config/site.js"

const {
  title = siteConfig.name,
  description = siteConfig.description,
  image,
  type,
  faqs,
  author,
  breadcrumbs,
  collectionType,
  definedTerm,
  definedTermSet,
} = Astro.props

const fullTitle = title === siteConfig.name || title.includes(siteConfig.name)
  ? title
  : `${title} | ${siteConfig.name}`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#22577A" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="license" href={siteConfig.license.url} />
    <Font cssVariable="--font-family-body" preload />
    <Font cssVariable="--font-family-heading" preload />
    <title>{fullTitle}</title>
    <SEO
      title={title}
      description={description}
      image={image}
      type={type}
      faqs={faqs}
      author={author}
      breadcrumbs={breadcrumbs}
      collectionType={collectionType}
      definedTerm={definedTerm}
      definedTermSet={definedTermSet}
    />
    <script is:inline async src="https://lyt.redemocratize.org/js/pa-KgasUmPVc-MlQHUL2hRcC.js"></script>
    <script is:inline>
      window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
      plausible.init()
    </script>
  </head>
  <body class="font-body">
    <Navigation />
    <div class="min-h-screen">
      <slot />
    </div>
    <footer class="footer footer-center p-10 bg-base-200 text-base-content">
      <aside>
        <p class="font-heading font-bold text-lg">Redemocratize</p>
        <p>An open-source constitutional design project.</p>
        <p class="text-sm opacity-70">
          Licensed under
          <a
            rel="license"
            href={siteConfig.license.url}
            class="link link-hover"
          >{siteConfig.license.name}</a>
        </p>
      </aside>
    </footer>
  </body>
</html>
