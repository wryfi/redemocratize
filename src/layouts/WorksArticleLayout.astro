---
/**
 * Layout for Democracy Works content pages. Replaces the generic
 * ContentLayout + ContentMeta combo with a department-header pattern that
 * preserves category orientation throughout the reading experience.
 */
import BaseLayout from "./BaseLayout.astro"
import TableOfContents from "../components/TableOfContents.astro"
import MobileTableOfContents from "../components/MobileTableOfContents.astro"
import WorksDepartmentHeader from "../components/WorksDepartmentHeader.astro"
import { getCollection } from "astro:content"
import { COLLECTION_CONFIG } from "../lib/works.js"

const {
  entry,
  collection,
  headings,
  breadcrumbs,
  status,
  country,
} = Astro.props

const cfg = COLLECTION_CONFIG[collection]

// Resolve principle ids to full principle entries
const principlesAll = await getCollection("principles")
const principlesById = Object.fromEntries(principlesAll.map((p) => [p.id, p]))
const principles = (entry.data.principles || [])
  .map((pid) => principlesById[pid])
  .filter(Boolean)
  .sort((a, b) => a.data.number - b.data.number)
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.summary}
  type="article"
  author={entry.data.author}
  breadcrumbs={breadcrumbs}
  collectionType={collection}
>
  {headings && headings.length > 0 && (
    <MobileTableOfContents headings={headings} />
  )}

  <div class="container max-w-6xl works-article" data-collection={collection}>
    <WorksDepartmentHeader
      entry={entry}
      collection={collection}
      principles={principles}
      status={status}
      country={country}
    />

    <div class="works-article-body">
      {headings && headings.length > 0 && (
        <aside class="works-article-toc hidden lg:block">
          <TableOfContents headings={headings} />
        </aside>
      )}

      <article class:list={["prose prose-lg max-w-none works-prose", { "has-toc": headings && headings.length > 0 }]}>
        <slot />
      </article>
    </div>

    <footer class="works-article-footer">
      <a href={cfg.href} class="works-article-back">
        <span aria-hidden="true">←</span>
        Back to {cfg.label}
      </a>
      <a href="/works" class="works-article-back-all">All Democracy Works</a>
    </footer>
  </div>
</BaseLayout>

<style>
  .works-article {
    padding-top: 0;
    padding-bottom: 4rem;
  }

  /* Ambient hue wash at the very top of the page */
  .works-article[data-collection="articles"] {
    background: radial-gradient(
      ellipse 80% 35% at 30% 0%,
      color-mix(in oklch, var(--color-badge-article) 22%, transparent),
      transparent 55%
    );
  }
  .works-article[data-collection="topics"] {
    background: radial-gradient(
      ellipse 80% 35% at 30% 0%,
      color-mix(in oklch, var(--color-badge-topic) 22%, transparent),
      transparent 55%
    );
  }
  .works-article[data-collection="proposals"] {
    background: radial-gradient(
      ellipse 80% 35% at 30% 0%,
      color-mix(in oklch, var(--color-badge-proposal) 22%, transparent),
      transparent 55%
    );
  }
  .works-article[data-collection="models"] {
    background: radial-gradient(
      ellipse 80% 35% at 30% 0%,
      color-mix(in oklch, var(--color-badge-model) 22%, transparent),
      transparent 55%
    );
  }
  .works-article[data-collection="news"] {
    background: radial-gradient(
      ellipse 80% 35% at 30% 0%,
      color-mix(in oklch, var(--color-badge-news) 22%, transparent),
      transparent 55%
    );
  }

  .works-article-body {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  @media (min-width: 1024px) {
    .works-article-body {
      flex-direction: row;
      gap: 3rem;
      align-items: flex-start;
    }
    .works-article-toc {
      width: 18rem;
      position: sticky;
      top: 5rem;
      flex-shrink: 0;
    }
    .works-prose.has-toc {
      flex: 1;
      min-width: 0;
    }
  }

  /* Retint the shared TableOfContents card so it sits on the page
     gradient rather than fighting it. Each collection tints the card
     with a wash of its badge hue and a matching border. */
  .works-article-toc :global(.card) {
    background: transparent;
    box-shadow: none;
    border: 1px solid var(--color-base-300);
    backdrop-filter: blur(2px);
  }
  .works-article[data-collection="articles"] .works-article-toc :global(.card) {
    background: color-mix(in oklch, var(--color-badge-article) 10%, transparent);
    border-color: color-mix(in oklch, var(--color-badge-article) 35%, var(--color-base-300));
  }
  .works-article[data-collection="topics"] .works-article-toc :global(.card) {
    background: color-mix(in oklch, var(--color-badge-topic) 10%, transparent);
    border-color: color-mix(in oklch, var(--color-badge-topic) 35%, var(--color-base-300));
  }
  .works-article[data-collection="proposals"] .works-article-toc :global(.card) {
    background: color-mix(in oklch, var(--color-badge-proposal) 10%, transparent);
    border-color: color-mix(in oklch, var(--color-badge-proposal) 35%, var(--color-base-300));
  }
  .works-article[data-collection="models"] .works-article-toc :global(.card) {
    background: color-mix(in oklch, var(--color-badge-model) 10%, transparent);
    border-color: color-mix(in oklch, var(--color-badge-model) 35%, var(--color-base-300));
  }
  .works-article[data-collection="news"] .works-article-toc :global(.card) {
    background: color-mix(in oklch, var(--color-badge-news) 10%, transparent);
    border-color: color-mix(in oklch, var(--color-badge-news) 35%, var(--color-base-300));
  }

  .works-article-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-base-300);
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 2rem;
    align-items: baseline;
  }
  .works-article-back {
    font-family: var(--font-family-heading);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-primary);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: gap 0.25s ease;
  }
  .works-article-back:hover {
    gap: 0.75rem;
  }
  .works-article-back-all {
    font-family: var(--font-family-heading);
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.55;
  }
  .works-article-back-all:hover {
    opacity: 0.9;
  }
</style>
